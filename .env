# Environment Configuration Template
# Copy this file to .env and update values as needed

# Database Configuration
DATABASE_URL=postgresql://ism_user:ism_password@localhost:5432/ism_db

# Service URLs (used by gateway)
AUTH_SERVICE_URL=http://localhost:8001
STUDENT_SERVICE_URL=http://localhost:8005
CURRICULUM_SERVICE_URL=http://localhost:8002
FINANCE_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8003
STAFF_SERVICE_URL=http://localhost:8006

# Logging
LOG_LEVEL=INFO

# API Configuration
API_TITLE=ISM - Integrated School Management System
API_VERSION=1.0.0
API_DESCRIPTION=Comprehensive school management system with microservices architecture

# Service Names
SERVICE_NAME=ism-service

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# JWT Configuration (add later)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ism.edu.ke

# SMS Configuration (if using SMS notifications)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-account-sid
SMS_AUTH_TOKEN=your-auth-token
SMS_FROM_NUMBER=+1234567890

# Environment
ENVIRONMENT=development

# Debug Mode
DEBUG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
